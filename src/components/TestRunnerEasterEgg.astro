<div
	id="test-runner-overlay"
	class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
	role="dialog"
	aria-label="Test run animation"
>
	<div class="w-[min(90vw,30rem)] overflow-hidden rounded-lg bg-[#1e1e1e] font-mono text-sm text-slate-300 shadow-2xl">
		<div class="flex items-center gap-1.5 bg-[#2d2d2d] px-3 py-2">
			<span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]"></span>
			<span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]"></span>
			<span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]"></span>
			<span class="ml-2 text-xs text-slate-500">Running Real-Time Smoke Tests</span>
			<span id="test-runner-progress" class="ml-auto text-xs text-slate-500"></span>
		</div>
		<div id="test-runner-lines" class="max-h-[320px] min-h-[260px] space-y-1 overflow-y-auto p-4"></div>
	</div>
</div>

<script>
	import { SMOKE_TESTS } from "@/data/smokeTests";

	const WORKER_URL = "https://cv-smoke-test-trigger.akosmakra.workers.dev";
	const RUN_LOOKUP_TIMEOUT_MS = 20000;
	const RUN_LOOKUP_INTERVAL_MS = 3000;
	const POLL_INTERVAL_MS = 3000;
	const OVERALL_TIMEOUT_MS = 180000;
	const TYPICAL_RUN_LABEL = "~1 min";
	const STORAGE_KEY = "cv-smoke-test-run";

	interface StoredRun {
		runId: number;
		startedAt: number;
	}

	function getStoredRun(): StoredRun | null {
		try {
			const raw = localStorage.getItem(STORAGE_KEY);
			if (!raw) return null;
			const parsed = JSON.parse(raw);
			if (typeof parsed.runId === "number" && typeof parsed.startedAt === "number") {
				if (Date.now() - parsed.startedAt < OVERALL_TIMEOUT_MS) return parsed;
			}
		} catch {
			// ignore malformed/inaccessible storage
		}
		return null;
	}

	function storeRun(runId: number, startedAt: number) {
		try {
			localStorage.setItem(STORAGE_KEY, JSON.stringify({ runId, startedAt }));
		} catch {
			// ignore storage failures (private browsing, quota, etc.)
		}
	}

	function clearStoredRun() {
		try {
			localStorage.removeItem(STORAGE_KEY);
		} catch {
			// ignore
		}
	}

	interface GhJob {
		name: string;
		status: string;
		conclusion: string | null;
	}

	type RowState = "pending" | "running" | "success" | "failed";

	const ICONS: Record<RowState, string> = {
		pending: `<svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle></svg>`,
		running: `<svg class="animate-spin" width="21" height="21" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" opacity="0.25"></circle><path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg>`,
		success: `<svg width="21" height="21" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="currentColor"></circle><path d="M8 12.5l2.5 2.5 5-5" stroke="#1e1e1e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg>`,
		failed: `<svg width="21" height="21" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="currentColor"></circle><path d="M9 9l6 6M15 9l-6 6" stroke="#1e1e1e" stroke-width="2" stroke-linecap="round"></path></svg>`,
	};

	const ROW_COLORS: Record<RowState, string> = {
		pending: "text-slate-600",
		running: "text-amber-300",
		success: "text-green-400",
		failed: "text-red-400",
	};

	function setRowState(row: HTMLElement, state: RowState, title: string) {
		row.className = `flex items-center gap-2 ${ROW_COLORS[state]}`;
		row.innerHTML = `<span class="shrink-0">${ICONS[state]}</span><span>${title}</span>`;
	}

	function makeLine(className: string, text: string): HTMLDivElement {
		const div = document.createElement("div");
		div.className = className;
		div.textContent = text;
		return div;
	}

	function wait(ms: number): Promise<void> {
		return new Promise((resolve) => setTimeout(resolve, ms));
	}

	function formatClock(ms: number): string {
		return new Date(ms).toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", timeZone: "UTC" }) + " UTC";
	}

	let activeRun = 0;

	async function runTestAnimation() {
		const myRun = ++activeRun;
		const isCurrent = () => myRun === activeRun;

		const overlay = document.getElementById("test-runner-overlay");
		const lines = document.getElementById("test-runner-lines");
		const progress = document.getElementById("test-runner-progress");
		if (!overlay || !lines) return;

		lines.innerHTML = "";
		overlay.classList.remove("hidden");
		overlay.classList.add("flex");

		const close = (e: Event) => {
			if (e.target === overlay || (e as KeyboardEvent).key === "Escape") {
				overlay.classList.add("hidden");
				overlay.classList.remove("flex");
				overlay.removeEventListener("click", close);
				document.removeEventListener("keydown", close);
			}
		};
		overlay.addEventListener("click", close);
		document.addEventListener("keydown", close);

		const updateProgress = (done: number) => {
			if (progress) progress.textContent = `${done}/${SMOKE_TESTS.length} passed`;
		};
		updateProgress(0);

		const existingRun = getStoredRun();

		const intro = makeLine(
			"text-slate-500",
			existingRun ? "A run is already in progress — resuming its live status…" : `Triggering ${SMOKE_TESTS.length} real tests on GitHub Actions…`,
		);
		lines.appendChild(intro);

		const timing = makeLine("text-xs text-slate-600", "");
		lines.appendChild(timing);

		const rows = new Map<string, HTMLDivElement>();
		SMOKE_TESTS.forEach((title) => {
			const row = document.createElement("div");
			lines.appendChild(row);
			rows.set(title, row);
			setRowState(row, "pending", title);
		});

		let startedAt = existingRun ? existingRun.startedAt : Date.now();
		let refreshPulseUntil = 0;

		const renderTiming = () => {
			const elapsed = Math.round((Date.now() - startedAt) / 1000);
			const refreshGlyph = Date.now() < refreshPulseUntil ? "↻" : "·";
			timing.textContent = `Refreshes every ${POLL_INTERVAL_MS / 1000}s ${refreshGlyph} ${TYPICAL_RUN_LABEL} typical runtime · ${elapsed}s elapsed`;
		};
		const pulseRefresh = () => {
			refreshPulseUntil = Date.now() + 600;
			renderTiming();
		};

		renderTiming();
		const timingInterval = window.setInterval(renderTiming, 1000);
		const stopTiming = () => window.clearInterval(timingInterval);

		let runId: number | null = existingRun ? existingRun.runId : null;

		if (runId === null) {
			let serverAlreadyRunning = false;
			try {
				const triggerRes = await fetch(`${WORKER_URL}/trigger`, { method: "POST" });
				if (!triggerRes.ok) throw new Error(`trigger failed (${triggerRes.status})`);
				const triggerData = await triggerRes.json();
				if (triggerData.alreadyRunning && typeof triggerData.startedAt === "number") {
					serverAlreadyRunning = true;
					startedAt = triggerData.startedAt;
				}
			} catch (err) {
				stopTiming();
				intro.className = "text-red-400";
				intro.textContent = `Couldn't start the test run (${err instanceof Error ? err.message : "network error"}). Try again in a moment.`;
				return;
			}

			intro.textContent = serverAlreadyRunning
				? `A run is already in progress (started ${formatClock(startedAt)}) — showing its live status…`
				: "Triggered — waiting for GitHub Actions to pick it up…";

			const lookupDeadline = Date.now() + RUN_LOOKUP_TIMEOUT_MS;
			while (Date.now() < lookupDeadline && runId === null) {
				await wait(RUN_LOOKUP_INTERVAL_MS);
				if (!isCurrent()) {
					stopTiming();
					return;
				}
				try {
					pulseRefresh();
					const res = await fetch(`${WORKER_URL}/runs`);
					if (res.status === 403) break;
					const data = await res.json();
					const match = (data.workflow_runs ?? []).find((run: { created_at: string }) => new Date(run.created_at).getTime() >= startedAt - 5000);
					if (match) runId = match.id;
				} catch {
					// transient network hiccup, keep retrying until the deadline
				}
			}

			if (runId === null) {
				stopTiming();
				intro.className = "text-amber-400";
				intro.textContent = "Triggered, but couldn't locate the run to track live — it's still running in the background.";
				return;
			}

			storeRun(runId, startedAt);
		}

		intro.textContent = "Tracking status via GitHub Actions";

		const overallDeadline = Date.now() + OVERALL_TIMEOUT_MS;
		let allDone = false;
		let rateLimited = false;

		while (Date.now() < overallDeadline && !allDone) {
			if (!isCurrent()) {
				stopTiming();
				return;
			}
			try {
				pulseRefresh();
				const res = await fetch(`${WORKER_URL}/jobs?run_id=${runId}`);
				if (res.status === 403) {
					rateLimited = true;
					break;
				}
				const data = await res.json();
				const jobs: GhJob[] = data.jobs ?? [];
				let doneCount = 0;

				jobs.forEach((job) => {
					const row = rows.get(job.name);
					if (!row) return;
					if (job.status === "completed") {
						doneCount++;
						setRowState(row, job.conclusion === "success" ? "success" : "failed", job.name);
					} else if (job.status === "in_progress") {
						setRowState(row, "running", job.name);
					}
				});

				updateProgress(doneCount);
				lines.scrollTop = lines.scrollHeight;

				if (jobs.length === SMOKE_TESTS.length && doneCount === SMOKE_TESTS.length) {
					allDone = true;
				}
			} catch {
				// transient network hiccup, keep polling until the deadline
			}

			if (!allDone) await wait(POLL_INTERVAL_MS);
		}

		stopTiming();
		clearStoredRun();
		const summary = makeLine(
			"mt-3 border-t border-slate-700 pt-2 font-semibold " + (allDone ? "text-green-400" : "text-amber-400"),
			allDone
				? `${SMOKE_TESTS.length}/${SMOKE_TESTS.length} passed · thanks for testing the deployed site 👋`
				: rateLimited
					? "Rate limit hit while checking status — the run is still going in the background."
					: "Taking longer than expected — the run is still going in the background.",
		);
		lines.appendChild(summary);
		lines.scrollTop = lines.scrollHeight;
	}

	window.addEventListener("run-tests-easter-egg", () => {
		void runTestAnimation();
	});
</script>
