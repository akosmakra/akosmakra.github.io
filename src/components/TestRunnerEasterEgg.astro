<div
	id="test-runner-overlay"
	class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
	role="dialog"
	aria-label="Test run animation"
>
	<div class="w-[min(90vw,28rem)] overflow-hidden rounded-lg bg-[#1e1e1e] font-mono text-sm text-slate-300 shadow-2xl">
		<div class="flex items-center gap-1.5 bg-[#2d2d2d] px-3 py-2">
			<span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]"></span>
			<span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]"></span>
			<span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]"></span>
			<span class="ml-2 text-xs text-slate-500">smoke.spec.ts</span>
		</div>
		<div id="test-runner-lines" class="min-h-[220px] space-y-1 p-4"></div>
	</div>
</div>

<script>
	const TESTS = [
		"page loads with the correct name and title",
		"sidebar shows a photo and a LinkedIn link",
		"experience and education sections are present",
		"dark mode toggle switches the theme",
		"download CV link points to a PDF",
		"external links open safely in a new tab",
		"no browser console errors on load",
	];

	function runTestAnimation() {
		const overlay = document.getElementById("test-runner-overlay");
		const lines = document.getElementById("test-runner-lines");
		if (!overlay || !lines) return;

		lines.innerHTML = "";
		overlay.classList.remove("hidden");
		overlay.classList.add("flex");

		TESTS.forEach((title, i) => {
			setTimeout(() => {
				const p = document.createElement("p");
				p.className = "text-slate-500";
				p.textContent = `⏳ ${title}`;
				lines.appendChild(p);

				setTimeout(() => {
					p.className = "text-green-400";
					p.textContent = `✓ ${title}`;
				}, 200);
			}, i * 260);
		});

		setTimeout(
			() => {
				const summary = document.createElement("p");
				summary.className = "mt-3 border-t border-slate-700 pt-2 font-semibold text-green-400";
				summary.textContent = `${TESTS.length} passed · thanks for testing the deploy 👋`;
				lines.appendChild(summary);
			},
			TESTS.length * 260 + 300,
		);

		const close = (e: Event) => {
			if (e.target === overlay || (e as KeyboardEvent).key === "Escape") {
				overlay.classList.add("hidden");
				overlay.classList.remove("flex");
				overlay.removeEventListener("click", close);
				document.removeEventListener("keydown", close);
			}
		};
		overlay.addEventListener("click", close);
		document.addEventListener("keydown", close);
	}

	window.addEventListener("run-tests-easter-egg", runTestAnimation);
</script>
