---
import { basics, skills, languages, achievements, awards } from "@cv";
import Mail from "@/icons/Mail.astro";
import Phone from "@/icons/Phone.astro";
import LinkedIn from "@/icons/LinkedIn.astro";

const { image, name, email, phone, profiles } = basics;
const linkedIn = profiles.find(({ network }) => network === "LinkedIn");

const SKILL_CATEGORY_ORDER = ["Test Automation & QA", "Programming & Scripting", "Tools & Version Control", "Systems & Monitoring"];

const skillsByCategory = SKILL_CATEGORY_ORDER.map((category) => ({
	category,
	items: skills.filter(({ keywords }) => keywords.includes(category)).map(({ name }) => name),
})).filter(({ items }) => items.length > 0);
---

<aside class="w-full shrink-0 bg-slate-900 px-8 py-12 text-slate-200 md:w-72 md:sticky md:top-0 md:h-screen md:overflow-y-auto print:h-auto print:w-64 print:bg-slate-900 print:text-slate-200 print:px-6 print:py-8">
	<img class="mx-auto aspect-square w-32 rounded-full object-cover shadow-lg" src={image} alt={name} />

	<div class="mt-8 flex flex-col gap-1.5 text-sm">
		{
			email && (
				<a href={`mailto:${email}`} class="flex items-center gap-2 text-slate-300 transition-colors hover:text-amber-400">
					<Mail />
					<span class="break-all">{email}</span>
				</a>
			)
		}
		{
			phone && (
				<a href={`tel:${phone}`} class="flex items-center gap-2 text-slate-300 transition-colors hover:text-amber-400">
					<Phone />
					<span>{phone}</span>
				</a>
			)
		}
		{
			linkedIn && (
				<a href={linkedIn.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-slate-300 transition-colors hover:text-amber-400">
					<LinkedIn />
					<span>LinkedIn</span>
				</a>
			)
		}
	</div>

	{
		skillsByCategory.length > 0 && (
			<div class="mt-8">
				<h4 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Skills</h4>
				<div class="mt-3 flex flex-col gap-3 text-sm">
					{skillsByCategory.map(({ category, items }) => (
						<div>
							<div class="text-xs font-semibold text-amber-400">{category}</div>
							<div class="text-slate-300">{items.join(", ")}</div>
						</div>
					))}
				</div>
			</div>
		)
	}

	{
		languages.length > 0 && (
			<div class="mt-8">
				<h4 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Languages</h4>
				<ul class="mt-3 flex flex-col gap-1 text-sm text-slate-300">
					{languages.map(({ language, fluency }) => (
						<li>
							{language} — {fluency}
						</li>
					))}
				</ul>
			</div>
		)
	}

	{
		achievements.length > 0 && (
			<div class="mt-8">
				<h4 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Achievements</h4>
				<ul class="mt-3 flex flex-col gap-2 text-sm text-slate-300">
					{achievements.map((achievement) => (
						<li>{achievement}</li>
					))}
				</ul>
			</div>
		)
	}

	{
		awards.length > 0 && (
			<div class="mt-8">
				<h4 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Scholarships</h4>
				<ul class="mt-3 flex flex-col gap-2 text-sm text-slate-300">
					{awards.map(({ title, date }) => (
						<li>
							{title} <span class="text-slate-400">({date})</span>
						</li>
					))}
				</ul>
			</div>
		)
	}
</aside>
