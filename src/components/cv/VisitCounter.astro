<div class="mt-3 inline-flex items-center gap-2 print:hidden">
	<span class="font-mono text-[10px] uppercase tracking-widest text-skin-muted">Visits</span>
	<span
		id="visit-counter"
		class="rounded border border-green-900/40 bg-black px-2 py-0.5 font-mono text-sm tracking-widest text-green-400"
		style="font-family: 'Courier New', monospace;"
	>
		- - - - - - -
	</span>
</div>

<script>
	const NAMESPACE = "akosmakra-cv";
	const KEY = "visits";

	async function updateVisitCounter() {
		const el = document.getElementById("visit-counter");
		if (!el) return;

		try {
			const cached = sessionStorage.getItem("visit-count");
			if (cached) {
				el.textContent = cached.padStart(7, "0");
				return;
			}

			const res = await fetch(`https://api.counterapi.dev/v1/${NAMESPACE}/${KEY}/up`);
			if (!res.ok) throw new Error("counter request failed");
			const data = await res.json();
			const count = String(data.count ?? "0");
			sessionStorage.setItem("visit-count", count);
			el.textContent = count.padStart(7, "0");
		} catch {
			el.textContent = "offline";
		}
	}

	updateVisitCounter();
</script>
