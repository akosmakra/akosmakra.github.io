---
const { className, title } = Astro.props;
---

<section class:list={["flex flex-col gap-4 print:gap-0", className]}>
	{title && <h2 class="relative flex w-full items-center gap-3 border-b-2 border-skin-hue pb-2 text-xl font-bold uppercase tracking-wide text-skin-base print:gap-1 print:pb-1 print:text-base">{title}</h2>}
	<slot />
</section>
