---
import { basics } from "@cv";
import ThemeSwitch from "@/components/ThemeSwitch.astro";

const { name, label } = basics;
---

<header class="flex flex-col gap-4 border-b-4 border-amber-500 pb-4 sm:flex-row sm:items-end sm:justify-between">
	<div>
		<h1 class="text-3xl font-bold text-skin-base sm:text-4xl">{name}</h1>
		<div class="mt-1 text-base italic text-skin-muted">{label}</div>
	</div>
	<div class="flex items-center gap-3">
		<ThemeSwitch />
		<button
			type="button"
			class="no-print group flex w-fit items-center gap-2 rounded-lg border border-skin-hue/40 bg-skin-hue/10 px-4 py-2 text-sm font-semibold text-[color-mix(in_srgb,var(--color-accent)_80%,black)] shadow-sm transition-all hover:border-skin-hue hover:bg-skin-hue/20 hover:shadow-md active:scale-95 dark:text-[color-mix(in_srgb,var(--color-accent)_80%,white)]"
			onclick="window.dispatchEvent(new CustomEvent('run-tests-easter-egg'))"
		>
			<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="shrink-0 transition-transform group-hover:scale-110" aria-hidden="true">
				<path d="M8 5v14l11-7z"></path>
			</svg>
			Run Smoke Tests Live
		</button>
		{import.meta.env.DEV && (
			<button
				type="button"
				title="Dev only — renders the failure UI locally without triggering a real run"
				class="no-print flex w-fit items-center gap-2 rounded-lg border border-dashed border-red-500/50 bg-red-500/10 px-4 py-2 text-sm font-semibold text-red-500 shadow-sm transition-all hover:border-red-500 hover:bg-red-500/20 active:scale-95"
				onclick="window.dispatchEvent(new CustomEvent('simulate-test-failure-easter-egg'))"
			>
				Simulate Failure
			</button>
		)}
		<a
			href="/cv.pdf"
			download
			class="no-print flex w-fit items-center gap-2 rounded-lg bg-skin-button-accent px-4 py-2 text-sm font-semibold text-skin-inverted transition-colors hover:bg-skin-button-accent-hover"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
				<polyline points="7 10 12 15 17 10" />
				<line x1="12" y1="15" x2="12" y2="3" />
			</svg>
			Download CV
		</a>
	</div>
</header>
