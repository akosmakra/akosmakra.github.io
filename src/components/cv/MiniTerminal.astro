---
import status from "@/data/status.json";

const { testsPassed, testCount, lighthouse, builtAt } = status;
const hasData = builtAt !== null;
---

<div class="mt-3 inline-block print:hidden" x-data="{ open: false }">
	<button
		type="button"
		@click="open = !open"
		class="flex items-center gap-1.5 rounded-md border border-skin-muted/40 px-2 py-1 font-mono text-xs text-skin-muted transition-colors hover:text-skin-base"
	>
		<span x-text="open ? '▾' : '▸'"></span>
		ci-log
	</button>

	<div
		x-show="open"
		x-transition
		x-cloak
		class="mt-2 w-[min(90vw,26rem)] overflow-hidden rounded-lg bg-[#1e1e1e] font-mono text-xs text-slate-300 shadow-lg"
	>
		<div class="flex items-center gap-1.5 bg-[#2d2d2d] px-3 py-2">
			<span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]"></span>
			<span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]"></span>
			<span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]"></span>
		</div>
		<div class="space-y-1.5 p-3">
			{hasData ? (
				<>
					<p><span class="text-slate-500">$</span> pnpm test</p>
					<p class="text-green-400">✓ {testCount} passed {!testsPassed && <span class="text-red-400">(some failing)</span>}</p>
					<p class="mt-2"><span class="text-slate-500">$</span> pnpm lighthouse</p>
					<p class="text-green-400">
						✓ perf {lighthouse.performance} · a11y {lighthouse.accessibility} · best-practices {lighthouse.bestPractices} · seo {lighthouse.seo}
					</p>
					<p class="mt-2"><span class="text-slate-500">$</span> pnpm deploy</p>
					<p class="text-green-400">✓ live at akosmakra.github.io</p>
				</>
			) : (
				<p class="text-slate-500">$ waiting for first scheduled quality check…</p>
			)}
		</div>
	</div>
</div>
