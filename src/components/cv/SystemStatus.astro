---
import status from "@/data/status.json";
import { SMOKE_TESTS } from "@/data/smokeTests";

const { builtAt, testsPassed, testCount } = status;

const formattedDate = builtAt
	? new Date(builtAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric", timeZone: "UTC" })
	: null;

function formatRunTime(date: Date) {
	return date.toLocaleString("en-GB", { day: "numeric", month: "short", hour: "2-digit", minute: "2-digit", timeZone: "UTC" }) + " UTC";
}

const QUALITY_CHECK_CRON_HOUR_UTC = 3;

const lastRun = builtAt ? new Date(builtAt) : null;

const nextRun = new Date();
nextRun.setUTCHours(QUALITY_CHECK_CRON_HOUR_UTC, 0, 0, 0);
if (nextRun.getTime() <= Date.now()) {
	nextRun.setUTCDate(nextRun.getUTCDate() + 1);
}

---

{
	formattedDate && (
		<div class="w-full pb-14 pt-2 flex flex-col items-center gap-1 print:hidden">
			<div class="text-[9px] text-skin-muted/35">Last updated {formattedDate}</div>
			{testCount > 0 && (
				<details class="group text-[9px] text-skin-muted/35">
					<summary class="cursor-pointer list-none marker:content-none">
						{testCount}/{testCount} smoke tests {testsPassed ? "passed" : "failed"}, last run: {lastRun && formatRunTime(lastRun)}, next run: {formatRunTime(nextRun)}
					</summary>
					<ul class="mx-auto mt-1.5 flex w-fit flex-col gap-0.5 text-left text-xs text-skin-muted">
						{SMOKE_TESTS.map((testName) => (
							<li class="flex items-center gap-1.5">
								<span class="text-green-400" aria-hidden="true">✓</span>
								{testName}
							</li>
						))}
					</ul>
					<button
						type="button"
						class="group mx-auto mt-2 flex w-fit items-center gap-2 rounded-full border border-skin-hue/40 bg-skin-hue/10 px-3.5 py-1.5 text-xs font-semibold text-skin-hue shadow-sm transition-all hover:border-skin-hue hover:bg-skin-hue/20 hover:shadow-md active:scale-95"
						onclick="window.dispatchEvent(new CustomEvent('run-tests-easter-egg'))"
					>
						<svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="shrink-0 transition-transform group-hover:scale-110" aria-hidden="true">
							<path d="M8 5v14l11-7z"></path>
						</svg>
						Run Smoke Tests Live
					</button>
				</details>
			)}
		</div>
	)
}

<style>
	summary::-webkit-details-marker {
		display: none;
	}
</style>
