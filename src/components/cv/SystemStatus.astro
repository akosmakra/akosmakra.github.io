---
import status from "@/data/status.json";
import { SMOKE_TESTS } from "@/data/smokeTests";

const { builtAt, testsPassed, testCount, lighthouse } = status;

const formattedDate = builtAt
	? new Date(builtAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric", timeZone: "Europe/Budapest" })
	: null;

function formatRunTime(date: Date) {
	return date.toLocaleString("en-GB", { day: "numeric", month: "short", hour: "2-digit", minute: "2-digit", timeZone: "Europe/Budapest", timeZoneName: "short" });
}

const QUALITY_CHECK_CRON_HOUR_UTC = 3;

const lastRun = builtAt ? new Date(builtAt) : null;

const nextRun = new Date();
nextRun.setUTCHours(QUALITY_CHECK_CRON_HOUR_UTC, 0, 0, 0);
if (nextRun.getTime() <= Date.now()) {
	nextRun.setUTCDate(nextRun.getUTCDate() + 1);
}

---

{
	formattedDate && (
		<div class="w-full pb-14 pt-2 flex flex-col items-center gap-1 print:hidden">
			<div class="text-[9px] text-skin-muted/35">Last updated {formattedDate}</div>
			{testCount > 0 && (
				<details class="group text-[9px] text-skin-muted/35">
					<summary class="inline-flex cursor-pointer list-none items-center gap-1 marker:content-none">
						<span>
							{testCount}/{testCount} smoke tests {testsPassed ? "passed" : "failed"}, last run: {lastRun && formatRunTime(lastRun)}, next run: {formatRunTime(nextRun)}
						</span>
						<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 transition-transform group-open:rotate-180" aria-hidden="true">
							<polyline points="6 9 12 15 18 9"></polyline>
						</svg>
					</summary>
					<ul class="mx-auto mt-1.5 flex w-fit flex-col gap-0.5 text-left text-xs text-skin-muted">
						{SMOKE_TESTS.map((testName) => (
							<li class="flex items-center gap-1.5">
								<span class="text-green-400" aria-hidden="true">✓</span>
								{testName}
							</li>
						))}
					</ul>
				</details>
			)}
			{lighthouse && (
				<div class="flex gap-2 text-[8px] text-skin-muted/20" title="Lighthouse scores">
					<span>⚡ {lighthouse.performance}</span>
					<span>♿ {lighthouse.accessibility}</span>
					<span>✓ {lighthouse.bestPractices}</span>
					<span>🔍 {lighthouse.seo}</span>
				</div>
			)}
		</div>
	)
}

<style>
	summary::-webkit-details-marker {
		display: none;
	}
</style>
