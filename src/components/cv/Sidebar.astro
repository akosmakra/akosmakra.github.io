---
import { basics, skills, languages, achievements, awards } from "@cv";
import Mail from "@/icons/Mail.astro";
import Phone from "@/icons/Phone.astro";
import LinkedIn from "@/icons/LinkedIn.astro";

const { image, name, email, phone, profiles } = basics;
const linkedIn = profiles.find(({ network }) => network === "LinkedIn");

const SKILL_CATEGORY_ORDER = ["Test Automation & QA", "Programming & Scripting", "Tools & Version Control", "Systems & Monitoring"];

const skillsByCategory = SKILL_CATEGORY_ORDER.map((category) => ({
	category,
	items: skills.filter(({ keywords }) => keywords.includes(category)).map(({ name }) => name),
})).filter(({ items }) => items.length > 0);
---

<aside class="w-full shrink-0 bg-slate-900 px-8 py-12 text-slate-200 md:w-72 md:sticky md:top-0 md:h-screen md:overflow-y-auto print:static print:h-auto print:w-full print:overflow-visible print:bg-slate-900 print:text-slate-200 print:px-6 print:py-8">
	<img class="mx-auto aspect-square w-40 rounded-full object-cover object-[center_13%] shadow-lg" src={image} alt={name} />

	<div class="mt-8 flex items-center justify-center gap-8 text-slate-300">
		{
			email && (
				<a href={`mailto:${email}`} aria-label={`Email: ${email}`} title={email} class="transition-colors hover:text-amber-400">
					<Mail />
				</a>
			)
		}
		{
			phone && (
				<a href={`tel:${phone}`} aria-label={`Phone: ${phone}`} title={phone} class="transition-colors hover:text-amber-400">
					<Phone />
				</a>
			)
		}
		{
			linkedIn && (
				<a href={linkedIn.url} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile" title="LinkedIn" class="transition-colors hover:text-amber-400">
					<LinkedIn />
				</a>
			)
		}
	</div>

	{
		skillsByCategory.length > 0 && (
			<div class="mt-8">
				<h3 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Skills</h3>
				<div class="mt-3 flex flex-col gap-3 text-sm">
					{skillsByCategory.map(({ category, items }) => (
						<div>
							<div class="text-xs font-semibold text-amber-400">{category}</div>
							<div class="text-slate-300">{items.join(", ")}</div>
						</div>
					))}
				</div>
			</div>
		)
	}

	{
		languages.length > 0 && (
			<div class="mt-8">
				<h3 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Languages</h3>
				<ul class="mt-3 flex flex-col gap-1 text-sm text-slate-300">
					{languages.map(({ language, fluency }) => (
						<li>
							{language} — {fluency}
						</li>
					))}
				</ul>
			</div>
		)
	}

	{
		achievements.length > 0 && (
			<div class="mt-8">
				<h3 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Personal Achievements</h3>
				<ul class="mt-3 flex flex-col gap-2 text-sm text-slate-300">
					{achievements.map((achievement) => (
						<li>{achievement}</li>
					))}
				</ul>
			</div>
		)
	}

	{
		awards.length > 0 && (
			<div class="mt-8">
				<h3 class="border-b-2 border-amber-500 pb-1 text-xs font-bold uppercase tracking-wide text-slate-100">Scholarships</h3>
				<ul class="mt-3 flex flex-col gap-2 text-sm text-slate-300">
					{awards.map(({ title, date }) => (
						<li>
							{title} <span class="text-slate-400">({date})</span>
						</li>
					))}
				</ul>
			</div>
		)
	}
</aside>

<style>
	/* Layout.astro sets a global h1-h4 color tied to the light/dark theme;
	   the sidebar is always dark, so its headings must stay light regardless of theme. */
	h3 {
		color: #f1f5f9;
	}
</style>
