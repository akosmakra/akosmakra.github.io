---
import status from "@/data/status.json";

const { builtAt, testsPassed, lighthouse } = status;

const formattedDate = builtAt
	? new Date(builtAt).toLocaleString("en-GB", { day: "numeric", month: "short", year: "numeric", timeZone: "UTC" })
	: null;

const lighthouseTitle = builtAt
	? `Lighthouse — Performance ${lighthouse.performance} · Accessibility ${lighthouse.accessibility} · Best Practices ${lighthouse.bestPractices} · SEO ${lighthouse.seo}`
	: "Lighthouse — not yet measured";
---

<div class="mt-2 flex items-center gap-2 text-xs text-skin-muted print:hidden" title={lighthouseTitle}>
	<span class={`inline-block h-1.5 w-1.5 rounded-full ${testsPassed ? "bg-green-600 dark:bg-green-400" : "bg-skin-muted"}`}></span>
	<span>{testsPassed === null ? "Not yet checked" : testsPassed ? "Tests passing" : "Tests failing"}</span>
	{formattedDate && <span>· last deploy {formattedDate}</span>}
</div>
