---
import { basics } from "@cv";

const { profiles } = basics;
const linkedinUrl = profiles.find((profile) => profile.network === "LinkedIn")?.url ?? "";
---

<div
	id="test-runner-overlay"
	class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/60 p-4"
	role="dialog"
	aria-label="Test run animation"
	data-contact-linkedin={linkedinUrl}
>
	<div class="flex max-h-[90vh] w-[min(94vw,43rem)] flex-col overflow-hidden rounded-xl bg-[#1e1e1e] font-mono text-sm text-slate-300 shadow-2xl">
		<div class="flex shrink-0 items-center gap-2 bg-[#2d2d2d] px-4 py-2.5">
			<span class="h-3 w-3 rounded-full bg-[#ff5f56]"></span>
			<span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
			<span class="h-3 w-3 rounded-full bg-[#27c93f]"></span>
			<span class="ml-2 text-xs text-slate-500">Running Real-Time Smoke Tests</span>
			<span id="test-runner-progress" class="ml-auto text-xs text-slate-500"></span>
		</div>
		<div id="test-runner-lines" class="min-h-[320px] flex-1 space-y-1.5 overflow-y-auto p-5"></div>
		<div class="flex shrink-0 justify-center border-t border-slate-700/60 bg-[#2d2d2d] px-4 py-3">
			<button
				type="button"
				id="test-runner-close"
				class="rounded-lg border border-slate-600 px-8 py-1.5 text-xs font-semibold text-slate-300 transition-all hover:border-slate-400 hover:bg-white/5 hover:text-white active:scale-95"
			>
				Close
			</button>
		</div>
	</div>
</div>

<script>
	import { SMOKE_TESTS } from "@/data/smokeTests";

	const WORKER_URL = "https://cv-smoke-test-trigger.akosmakra.workers.dev";
	const RUN_LOOKUP_TIMEOUT_MS = 20000;
	const RUN_LOOKUP_INTERVAL_MS = 3000;
	const POLL_INTERVAL_MS = 3000;
	const OVERALL_TIMEOUT_MS = 180000;
	const TYPICAL_RUN_LABEL = "~1 min";
	const STORAGE_KEY = "cv-smoke-test-run";

	interface StoredRun {
		runId: number;
		startedAt: number;
		expiresAt: number | null;
	}

	function getStoredRun(): StoredRun | null {
		try {
			const raw = localStorage.getItem(STORAGE_KEY);
			if (!raw) return null;
			const parsed = JSON.parse(raw);
			if (typeof parsed.runId === "number" && typeof parsed.startedAt === "number") {
				if (Date.now() - parsed.startedAt < OVERALL_TIMEOUT_MS) {
					return { runId: parsed.runId, startedAt: parsed.startedAt, expiresAt: typeof parsed.expiresAt === "number" ? parsed.expiresAt : null };
				}
			}
		} catch {
			// ignore malformed/inaccessible storage
		}
		return null;
	}

	function storeRun(runId: number, startedAt: number, expiresAt: number | null) {
		try {
			localStorage.setItem(STORAGE_KEY, JSON.stringify({ runId, startedAt, expiresAt }));
		} catch {
			// ignore storage failures (private browsing, quota, etc.)
		}
	}

	function clearStoredRun() {
		try {
			localStorage.removeItem(STORAGE_KEY);
		} catch {
			// ignore
		}
	}

	interface GhJob {
		name: string;
		status: string;
		conclusion: string | null;
	}

	type RowState = "pending" | "running" | "success" | "failed";

	const ICONS: Record<RowState, string> = {
		pending: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle></svg>`,
		running: `<svg class="animate-spin" width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" opacity="0.25"></circle><path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path></svg>`,
		success: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="currentColor"></circle><path d="M8 12.5l2.5 2.5 5-5" stroke="#1e1e1e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path></svg>`,
		failed: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" fill="currentColor"></circle><path d="M9 9l6 6M15 9l-6 6" stroke="#1e1e1e" stroke-width="2" stroke-linecap="round"></path></svg>`,
	};

	const ROW_COLORS: Record<RowState, string> = {
		pending: "text-slate-600",
		running: "text-amber-300",
		success: "text-green-400",
		failed: "text-red-400",
	};

	function setRowState(row: HTMLElement, state: RowState, title: string) {
		row.className = `flex items-center gap-3 py-0.5 text-[15px] ${ROW_COLORS[state]}`;
		row.innerHTML = `<span class="shrink-0">${ICONS[state]}</span><span>${title}</span>`;
	}

	function makeLine(className: string, text: string): HTMLDivElement {
		const div = document.createElement("div");
		div.className = className;
		div.textContent = text;
		return div;
	}

	function wait(ms: number): Promise<void> {
		return new Promise((resolve) => setTimeout(resolve, ms));
	}

	function formatClock(ms: number): string {
		return new Date(ms).toLocaleTimeString("en-GB", { hour: "2-digit", minute: "2-digit", timeZone: "Europe/Budapest", timeZoneName: "short" });
	}

	function attachCloseHandlers(overlay: HTMLElement, closeButton: HTMLElement | null) {
		const close = (e: Event) => {
			const isBackdrop = e.target === overlay;
			const isEscape = (e as KeyboardEvent).key === "Escape";
			const isCloseButton = e.currentTarget === closeButton;
			if (isBackdrop || isEscape || isCloseButton) {
				overlay.classList.add("hidden");
				overlay.classList.remove("flex");
				overlay.removeEventListener("click", close);
				document.removeEventListener("keydown", close);
				closeButton?.removeEventListener("click", close);
			}
		};
		overlay.addEventListener("click", close);
		document.addEventListener("keydown", close);
		closeButton?.addEventListener("click", close);
	}

	function renderResultSummary(lines: HTMLElement, overlay: HTMLElement, finalPassedCount: number, allDone: boolean, rateLimited: boolean) {
		const fullyPassed = allDone && finalPassedCount === SMOKE_TESTS.length;

		const summary = makeLine(
			"mt-4 border-t border-slate-700 pt-3 text-[15px] font-semibold " + (fullyPassed ? "text-green-400" : "text-amber-400"),
			allDone
				? fullyPassed
					? `${SMOKE_TESTS.length}/${SMOKE_TESTS.length} passed · thanks for testing the deployed site 👋`
					: `${finalPassedCount}/${SMOKE_TESTS.length} passed`
				: rateLimited
					? "Rate limit hit while checking status — the run is still going in the background."
					: "Taking longer than expected — the run is still going in the background.",
		);
		lines.appendChild(summary);

		if (allDone && !fullyPassed) {
			const contactLinkedin = overlay.dataset.contactLinkedin ?? "";
			const contact = document.createElement("div");
			contact.className = "mt-2 text-[13px] font-normal text-slate-400";
			contact.innerHTML = `Oops, something broke — that's exactly why smoke tests exist. I've already been notified on multiple platforms, but if you want to make sure I see it, feel free to reach out on <a class="underline hover:text-slate-200" href="${contactLinkedin}" target="_blank" rel="noopener noreferrer">LinkedIn</a>.`;
			lines.appendChild(contact);
		}

		lines.scrollTop = lines.scrollHeight;
	}

	let activeRun = 0;

	async function runTestAnimation() {
		const myRun = ++activeRun;
		const isCurrent = () => myRun === activeRun;

		const overlay = document.getElementById("test-runner-overlay");
		const lines = document.getElementById("test-runner-lines");
		const progress = document.getElementById("test-runner-progress");
		if (!overlay || !lines) return;

		lines.innerHTML = "";
		overlay.classList.remove("hidden");
		overlay.classList.add("flex");

		attachCloseHandlers(overlay, document.getElementById("test-runner-close"));

		const updateProgress = (done: number) => {
			if (progress) progress.textContent = `${done}/${SMOKE_TESTS.length} passed`;
		};
		updateProgress(0);

		const existingRun = getStoredRun();

		const statusLog = document.createElement("div");
		statusLog.className = "mb-3 flex flex-col gap-1 text-[15px]";
		lines.appendChild(statusLog);

		const statusLines: HTMLDivElement[] = [];
		const ACTIVE_STATUS_CLASS = "text-slate-300";
		const PAST_STATUS_CLASS = "text-slate-600";

		function logStatus(text: string, activeClass: string = ACTIVE_STATUS_CLASS): HTMLDivElement {
			statusLines.forEach((el) => {
				el.className = `${PAST_STATUS_CLASS} transition-colors`;
			});
			const line = makeLine(`${activeClass} transition-colors`, text);
			statusLog.appendChild(line);
			statusLines.push(line);
			return line;
		}

		function dimAllStatusLines() {
			statusLines.forEach((el) => {
				el.className = `${PAST_STATUS_CLASS} transition-colors`;
			});
		}

		logStatus(
			existingRun
				? "Showing the status of the most recent run…"
				: `Triggering ${SMOKE_TESTS.length} real tests on GitHub Actions… (typically ${TYPICAL_RUN_LABEL})`,
		);

		const timing = document.createElement("div");
		timing.className = "mb-2 grid grid-cols-3 divide-x divide-slate-700/60 rounded-lg border border-slate-700/60 bg-black/20 py-2.5 text-[14px]";
		lines.appendChild(timing);

		const rows = new Map<string, HTMLDivElement>();
		SMOKE_TESTS.forEach((title) => {
			const row = document.createElement("div");
			lines.appendChild(row);
			rows.set(title, row);
			setRowState(row, "pending", title);
		});

		let startedAt = existingRun ? existingRun.startedAt : Date.now();
		let expiresAt = existingRun ? existingRun.expiresAt : null;
		let refreshPulseUntil = 0;
		let timingInterval = 0;
		const stopTiming = () => window.clearInterval(timingInterval);

		const renderReady = () => {
			timing.className = "mb-2 flex items-center gap-2 rounded-lg border border-green-500/50 bg-green-500/10 px-4 py-2.5 text-[14px] font-semibold text-green-400";
			timing.innerHTML = `<span aria-hidden="true">●</span> Cooldown over — you can run these again`;
		};

		const renderCooldownOnly = () => {
			if (!isCurrent()) {
				stopTiming();
				return;
			}
			if (expiresAt === null || Date.now() >= expiresAt) {
				renderReady();
				stopTiming();
				return;
			}
			const elapsed = Math.round((Date.now() - startedAt) / 1000);
			const remaining = Math.ceil((expiresAt - Date.now()) / 1000);
			timing.className = "mb-2 grid grid-cols-2 divide-x divide-slate-700/60 rounded-lg border border-slate-700/60 bg-black/20 py-2.5 text-[14px]";
			timing.innerHTML = `
				<div class="flex flex-col items-center gap-0.5 px-3">
					<span class="text-[11px] uppercase tracking-wider text-slate-500">Elapsed</span>
					<span class="font-semibold text-slate-300">${elapsed}s</span>
				</div>
				<div class="flex flex-col items-center gap-0.5 px-3">
					<span class="text-[11px] uppercase tracking-wider text-slate-500">Cooldown</span>
					<span class="font-semibold text-amber-300">${remaining}s</span>
				</div>
			`;
		};

		const renderTiming = () => {
			const elapsed = Math.round((Date.now() - startedAt) / 1000);
			const refreshGlyph = Date.now() < refreshPulseUntil ? "↻" : "·";
			const nextLabel = expiresAt === null ? "—" : Date.now() >= expiresAt ? "now" : `${Math.ceil((expiresAt - Date.now()) / 1000)}s`;
			timing.innerHTML = `
				<div class="flex flex-col items-center gap-0.5 px-3">
					<span class="text-[11px] uppercase tracking-wider text-slate-500">Elapsed</span>
					<span class="font-semibold text-slate-300">${elapsed}s</span>
				</div>
				<div class="flex flex-col items-center gap-0.5 px-3">
					<span class="text-[11px] uppercase tracking-wider text-slate-500">Cooldown</span>
					<span class="font-semibold text-amber-300">${nextLabel}</span>
				</div>
				<div class="flex flex-col items-center gap-0.5 px-3">
					<span class="text-[11px] uppercase tracking-wider text-slate-500">Refresh</span>
					<span class="text-slate-400">${refreshGlyph} ${POLL_INTERVAL_MS / 1000}s</span>
				</div>
			`;
		};
		const pulseRefresh = () => {
			refreshPulseUntil = Date.now() + 600;
			renderTiming();
		};

		renderTiming();
		timingInterval = window.setInterval(renderTiming, 1000);

		let runId: number | null = existingRun ? existingRun.runId : null;

		if (runId === null) {
			let serverAlreadyRunning = false;
			try {
				const triggerRes = await fetch(`${WORKER_URL}/trigger`, { method: "POST" });
				if (!triggerRes.ok) throw new Error(`trigger failed (${triggerRes.status})`);
				const triggerData = await triggerRes.json();
				if (typeof triggerData.expiresAt === "number") expiresAt = triggerData.expiresAt;
				if (triggerData.alreadyRunning && typeof triggerData.startedAt === "number") {
					serverAlreadyRunning = true;
					startedAt = triggerData.startedAt;
				}
			} catch (err) {
				stopTiming();
				logStatus(`Couldn't start the test run (${err instanceof Error ? err.message : "network error"}). Try again in a moment.`, "text-red-400");
				return;
			}

			logStatus(
				serverAlreadyRunning
					? `A run from ${formatClock(startedAt)} is still on cooldown — showing its status…`
					: "Triggered — waiting for GitHub Actions to pick it up…",
			);

			const lookupDeadline = Date.now() + RUN_LOOKUP_TIMEOUT_MS;
			while (Date.now() < lookupDeadline && runId === null) {
				await wait(RUN_LOOKUP_INTERVAL_MS);
				if (!isCurrent()) {
					stopTiming();
					return;
				}
				try {
					pulseRefresh();
					const res = await fetch(`${WORKER_URL}/runs`);
					if (res.status === 403) break;
					const data = await res.json();
					const match = (data.workflow_runs ?? []).find((run: { created_at: string }) => new Date(run.created_at).getTime() >= startedAt - 5000);
					if (match) runId = match.id;
				} catch {
					// transient network hiccup, keep retrying until the deadline
				}
			}

			if (runId === null) {
				stopTiming();
				logStatus("Triggered, but couldn't locate the run to track live — it's still running in the background.", "text-amber-400");
				return;
			}

			storeRun(runId, startedAt, expiresAt);
		}

		logStatus("Tracking status via GitHub Actions");

		const overallDeadline = Date.now() + OVERALL_TIMEOUT_MS;
		let allDone = false;
		let rateLimited = false;
		let finalPassedCount = 0;

		while (Date.now() < overallDeadline && !allDone) {
			if (!isCurrent()) {
				stopTiming();
				return;
			}
			try {
				pulseRefresh();
				const res = await fetch(`${WORKER_URL}/jobs?run_id=${runId}`);
				if (res.status === 403) {
					rateLimited = true;
					break;
				}
				const data = await res.json();
				const jobs: GhJob[] = data.jobs ?? [];
				let completedCount = 0;
				let passedCount = 0;

				jobs.forEach((job) => {
					const row = rows.get(job.name);
					if (!row) return;
					if (job.status === "completed") {
						completedCount++;
						const success = job.conclusion === "success";
						if (success) passedCount++;
						setRowState(row, success ? "success" : "failed", job.name);
					} else if (job.status === "in_progress") {
						setRowState(row, "running", job.name);
					}
				});

				updateProgress(passedCount);
				finalPassedCount = passedCount;
				lines.scrollTop = lines.scrollHeight;

				if (completedCount === SMOKE_TESTS.length) {
					allDone = true;
				}
			} catch {
				// transient network hiccup, keep polling until the deadline
			}

			if (!allDone) await wait(POLL_INTERVAL_MS);
		}

		clearStoredRun();
		stopTiming();
		dimAllStatusLines();
		if (expiresAt !== null && Date.now() < expiresAt) {
			renderCooldownOnly();
			timingInterval = window.setInterval(renderCooldownOnly, 1000);
		} else {
			renderReady();
		}
		renderResultSummary(lines, overlay, finalPassedCount, allDone, rateLimited);
	}

	function runSimulatedFailure() {
		const overlay = document.getElementById("test-runner-overlay");
		const lines = document.getElementById("test-runner-lines");
		const progress = document.getElementById("test-runner-progress");
		if (!overlay || !lines) return;

		activeRun++;
		lines.innerHTML = "";
		overlay.classList.remove("hidden");
		overlay.classList.add("flex");

		attachCloseHandlers(overlay, document.getElementById("test-runner-close"));

		const statusLog = document.createElement("div");
		statusLog.className = "mb-3 flex flex-col gap-1 text-[15px]";
		statusLog.appendChild(makeLine("text-amber-300", "⚠ Simulated run (dev only) — no real tests were triggered"));
		lines.appendChild(statusLog);

		const failingIndex = Math.floor(Math.random() * SMOKE_TESTS.length);
		let passedCount = 0;
		SMOKE_TESTS.forEach((title, i) => {
			const row = document.createElement("div");
			lines.appendChild(row);
			const isFailing = i === failingIndex;
			if (!isFailing) passedCount++;
			setRowState(row, isFailing ? "failed" : "success", title);
		});

		if (progress) progress.textContent = `${passedCount}/${SMOKE_TESTS.length} passed`;

		renderResultSummary(lines, overlay, passedCount, true, false);
	}

	window.addEventListener("run-tests-easter-egg", () => {
		void runTestAnimation();
	});

	if (import.meta.env.DEV) {
		window.addEventListener("simulate-test-failure-easter-egg", runSimulatedFailure);
	}
</script>
