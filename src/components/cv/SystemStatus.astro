---
import status from "@/data/status.json";

const { builtAt } = status;

const formattedDate = builtAt
	? new Date(builtAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric", timeZone: "UTC" })
	: null;
---

{formattedDate && <p class="mt-2 text-[11px] text-skin-muted/60 print:hidden">Last updated {formattedDate}</p>}
